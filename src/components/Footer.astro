---
interface Props {
  brand: {
    name: string;
    homeLabel: string;
  };
  footer: {
    description: string;
    styles: string;
    contact: string;
    contactLine1: string;
    contactLine2: string;
    contactLine3: string;
    copyright: string;
  };
  styles: {
    id: string;
    name: string;
  }[];
}

const { brand, footer, styles } = Astro.props;
---

<footer class="border-t border-charcoal/10 bg-charcoal text-ivory">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-[1.4fr_1fr_1fr] lg:px-8">
    <div>
      <a href="#top" class="inline-flex items-center gap-4" aria-label={brand.homeLabel}>
        <span class="grid size-16 place-items-center overflow-hidden rounded border border-white/12 bg-white">
          <img src="/images/logo.png" alt="" class="h-full w-full object-contain p-1.5" width="1276" height="1344" loading="lazy" />
        </span>
        <span class="text-xl font-black uppercase tracking-normal">{brand.name}</span>
      </a>
      <p class="mt-4 max-w-md text-sm leading-6 text-ivory/72">
        {footer.description}
      </p>
    </div>
    <div>
      <a href="#styles" class="text-sm font-black uppercase tracking-normal text-honey transition hover:text-blush">{footer.styles}</a>
      <ul class="mt-4 grid gap-2 text-sm text-ivory/72">
        {styles.map((style) => (
          <li>
            <a href={`#${style.id}`} class="transition hover:text-honey">{style.name}</a>
          </li>
        ))}
      </ul>
    </div>
    <div>
      <a href="#contact" class="text-sm font-black uppercase tracking-normal text-honey transition hover:text-blush">{footer.contact}</a>
      <ul class="mt-4 grid gap-2 text-sm text-ivory/72">
        <li><a href="#contact" class="transition hover:text-honey">{footer.contactLine1}</a></li>
        <li><a href="#contact" class="transition hover:text-honey">{footer.contactLine2}</a></li>
        <li><a href="#contact" class="transition hover:text-honey">{footer.contactLine3}</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10 px-4 py-5 text-center text-xs text-ivory/48">
    © {new Date().getFullYear()} {brand.name}. {footer.copyright}
  </div>
</footer>
