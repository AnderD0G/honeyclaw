---
interface Props {
  eyebrow?: string;
}

const { eyebrow = 'Custom Quote' } = Astro.props;
---

<section class="bg-charcoal px-4 py-16 text-ivory sm:px-6 lg:px-8">
  <div class="mx-auto grid max-w-7xl gap-8 md:grid-cols-[1.3fr_0.7fr] md:items-center">
    <div>
      <p class="text-sm font-black uppercase tracking-normal text-honey">{eyebrow}</p>
      <h2 class="mt-3 max-w-3xl text-3xl font-black leading-tight sm:text-4xl">Looking for press-on nail designs in a specific style?</h2>
      <p class="mt-5 max-w-2xl text-base leading-7 text-ivory/74">
        Send us your target quantity, preferred style direction and packaging needs for a custom quote.
      </p>
    </div>
    <a href="#contact" class="inline-flex w-full items-center justify-center rounded bg-honey px-6 py-4 text-sm font-black text-charcoal transition hover:bg-blush md:w-auto md:justify-self-end">
      Contact Us
    </a>
  </div>
</section>
