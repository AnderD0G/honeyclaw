---
import { defaultLanguage, languages } from '../i18n/config';

const languageCodes = Object.keys(languages);
---

<!doctype html>
<html lang={defaultLanguage}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`1; url=/${defaultLanguage}/`} />
    <title>HoneyClaw Nails</title>
    <script is:inline define:vars={{ languageCodes, defaultLanguage }}>
      const supportedLanguages = new Set(languageCodes);

      function normalizeLanguage(value) {
        const language = String(value || '').toLowerCase().split('-')[0];
        return supportedLanguages.has(language) ? language : null;
      }

      function redirect(language) {
        const targetLanguage = supportedLanguages.has(language) ? language : defaultLanguage;
        window.location.replace(`/${targetLanguage}/${window.location.hash || ''}`);
      }

      (() => {
        const params = new URLSearchParams(window.location.search);
        const queryLanguage = normalizeLanguage(params.get('lang'));
        if (queryLanguage) {
          localStorage.setItem('preferredLanguage', queryLanguage);
          redirect(queryLanguage);
          return;
        }

        const storedLanguage = normalizeLanguage(localStorage.getItem('preferredLanguage'));
        if (storedLanguage) {
          redirect(storedLanguage);
          return;
        }

        redirect(normalizeLanguage(navigator.language) || defaultLanguage);
      })();
    </script>
  </head>
  <body>
    <p>
      Redirecting to <a href={`/${defaultLanguage}/`}>HoneyClaw Nails</a>.
    </p>
  </body>
</html>
